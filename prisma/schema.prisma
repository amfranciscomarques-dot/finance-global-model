// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENTITIES & ORGANIZATIONAL STRUCTURE
// ==========================================

model Entity {
  id                    String    @id @default(cuid())
  code                  String    @unique                    // Entity code, e.g. GRSTL, ECOGRES
  legalName             String
  countryCode           String                               // PT, ES, DE, FR, UK
  localCurrency         String                               // EUR, GBP, etc.
  consolidationMethod   String    @default("full")           // full, proportional, equity
  ownershipPercentage   Float     @default(1.0)              // 0.0 to 1.0
  sector                String?                              // Technology, Manufacturing, etc.
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  trialBalances         TrialBalance[]
  intercompanyFrom      IntercompanyTransaction[] @relation("FromEntity")
  intercompanyTo        IntercompanyTransaction[] @relation("ToEntity")
  budgetEntries         BudgetEntry[]
  forecastEntries       ForecastEntry[]
  taxCarryforwards      TaxCarryforward[]
}

// ==========================================
// CHART OF ACCOUNTS (Group COA)
// ==========================================

model ChartOfAccount {
  id                    String    @id @default(cuid())
  code                  String    @unique                    // Group COA code
  name                  String
  accountType           String                               // asset, liability, equity, revenue, expense
  statementType         String                               // income, balance, cashflow
  parentCode            String?                              // For hierarchical COA
  level                 Int       @default(1)                // 1=Group, 2=Sub-group, 3=Detail
  isIntercompany        Boolean   @default(false)            // IC account flag
  sortOrder             Int       @default(0)

  localMappings         COAMapping[]
  trialBalances         TrialBalance[]
  budgetEntries         BudgetEntry[]
  forecastEntries       ForecastEntry[]
}

// ==========================================
// COA MAPPING (Local COA → Group COA)
// ==========================================

model COAMapping {
  id                    String    @id @default(cuid())
  entityCode            String                               // Entity code
  localAccountCode      String                               // Local ERP account code
  localAccountName      String                               // Local account name
  localCOAType          String                               // SNC, PGC, HGB, IFRS
  groupCOACode          String                               // Maps to ChartOfAccount.code
  groupCOA              ChartOfAccount @relation(fields: [groupCOACode], references: [code])
  createdAt             DateTime  @default(now())

  @@unique([entityCode, localAccountCode])   // one local account per entity maps to a single group account
  @@index([groupCOACode])
}

// ==========================================
// EXCHANGE RATES
// ==========================================

model ExchangeRate {
  id                    String    @id @default(cuid())
  currency              String                               // GBP, USD, etc.
  rateDate              DateTime                             // Date of the rate
  rateType              String    @default("closing")        // closing, average, historical
  rate                  Float                                 // Rate to EUR (1 EUR = X currency)
  source                String    @default("ECB")            // ECB, manual
  createdAt             DateTime  @default(now())

  @@unique([currency, rateDate, rateType])
}

// ==========================================
// TRIAL BALANCE (Ingested from ERPs)
// ==========================================

model TrialBalance {
  id                    String    @id @default(cuid())
  entityId              String
  entity                Entity    @relation(fields: [entityId], references: [id])
  period                DateTime                             // YYYY-MM-01
  periodType            String    @default("actual")         // actual, budget, forecast
  groupCOACode          String
  groupCOA              ChartOfAccount @relation(fields: [groupCOACode], references: [code])
  amountLocal           Float                                 // Amount in local currency
  amountEUR             Float                                 // Amount converted to EUR
  currency              String                               // Original currency
  exchangeRateUsed      Float?                               // Rate applied
  sourceSystem          String    @default("manual")         // SAP, Oracle, manual
  isIntercompany        Boolean   @default(false)
  icPartnerEntityId     String?                              // Counterparty entity for IC
  eliminationStatus     String    @default("pending")        // pending, matched, eliminated
  eliminationGroup      String?                              // Group for IC matching
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([entityId, period])
  @@index([groupCOACode])
  @@index([eliminationStatus])
}

// ==========================================
// INTERCOMPANY TRANSACTIONS
// ==========================================

model IntercompanyTransaction {
  id                    String    @id @default(cuid())
  transactionId         String    @unique                    // IC-PT0001-20240101
  fromEntityId          String
  fromEntity            Entity    @relation("FromEntity", fields: [fromEntityId], references: [id])
  toEntityId            String
  toEntity              Entity    @relation("ToEntity", fields: [toEntityId], references: [id])
  amount                Float
  currency              String
  amountEUR             Float
  transactionType       String                               // sale, purchase, loan, dividend, service
  matchingReference     String?                              // For bilateral matching
  period                DateTime
  isEliminated          Boolean   @default(false)
  eliminationGroup      String?
  // Transfer-pricing metadata for intra-group GOODS sales (sale/purchase). Drives
  // the unrealized-inventory-profit elimination (MEDIUM.8b). Both nullable; when
  // absent the engine falls back to the group's default TransferPricingPolicy.
  markup                Float?                               // cost-plus markup on the transfer price (e.g. 0.30)
  closingInventoryFraction Float?                            // fraction of the goods still in the buyer's closing inventory (0..1)
  createdAt             DateTime  @default(now())
}

// ==========================================
// BUDGET ENTRIES
// ==========================================

model BudgetEntry {
  id                    String    @id @default(cuid())
  entityId              String
  entity                Entity    @relation(fields: [entityId], references: [id])
  period                DateTime
  groupCOACode          String
  groupCOA              ChartOfAccount @relation(fields: [groupCOACode], references: [code])
  amountLocal           Float
  amountEUR             Float
  currency              String
  budgetVersion         String    @default("v1")             // v1, v2, etc.
  createdAt             DateTime  @default(now())

  @@index([entityId, period])
}

// ==========================================
// FORECAST ENTRIES (Rolling Forecasts)
// ==========================================

model ForecastEntry {
  id                    String    @id @default(cuid())
  entityId              String
  entity                Entity    @relation(fields: [entityId], references: [id])
  period                DateTime
  groupCOACode          String
  groupCOA              ChartOfAccount @relation(fields: [groupCOACode], references: [code])
  amountLocal           Float
  amountEUR             Float
  currency              String
  forecastVersion       String    @default("rf1")            // rf1, rf2, etc.
  scenarioType          String    @default("base")           // base, optimistic, pessimistic
  createdAt             DateTime  @default(now())

  @@index([entityId, period, scenarioType])
}

// ==========================================
// CONSOLIDATION RUNS (Audit Trail)
// ==========================================

model ConsolidationRun {
  id                    String    @id @default(cuid())
  period                DateTime
  entityCodes           String                               // JSON array of entity codes
  scenarioType          String    @default("base")           // base, optimistic, pessimistic
  status                String    @default("completed")      // running, completed, failed
  balanceCheck          Float?                               // signed assets − (liab + equity) imbalance; ~0 when balanced, recorded even on failed runs
  taxDriftEUR           Float?                               // signed group tax drift (stored − modelled IRC); null when not comparable (B3)
  taxComparable         Boolean?                             // false if any entity hit an unmodelled-jurisdiction provider
  eliminationsApplied   Int       @default(0)
  totalRevenue          Float?
  totalEBITDA           Float?
  totalNetIncome        Float?
  totalAssets           Float?
  netDebt               Float?
  ebitdaMargin          Float?
  leverage              Float?
  processingTimeMs      Float?
  createdAt             DateTime  @default(now())
}

// ==========================================
// TAX CARRYFORWARDS (per-entity loss & credit pools, persisted year-on-year)
//
// The tax module computes each entity's closing NOL pool (prejuízo fiscal,
// art.º 52.º CIRC) and unused RFAI credit (art.º 23.º CFI) for a year. Storing
// them lets the NEXT year's consolidation feed them back as the opening pools
// (nolOpening / rfaiOpening), which is what makes the IAS 12 deferred tax
// (MEDIUM.8b) dynamic across a multi-year run. Keyed per (entity, year,
// scenario) so base actuals and forecast scenarios keep independent pools.
// ==========================================

model TaxCarryforward {
  id                    String    @id @default(cuid())
  entityId              String
  entity                Entity    @relation(fields: [entityId], references: [id])
  year                  Int                                  // fiscal year these closing pools belong to
  scenarioType          String    @default("base")           // base, optimistic, pessimistic
  nolClosing            Float     @default(0)                // loss pool carried forward (art.º 52.º CIRC)
  rfaiClosing           Float     @default(0)                // unused RFAI credit carried forward (art.º 23.º CFI)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([entityId, year, scenarioType])
  @@index([entityId, year])
}

// ==========================================
// PROJECTS (Investment appraisal, e.g. Automation & Logistics Hub)
// ==========================================

model Project {
  id                    String    @id @default(cuid())
  code                  String    @unique                    // PRJ-HUB, etc.
  name                  String
  entityCode            String                               // Owning entity (e.g. MERID)
  countryCode           String    @default("PT")             // Jurisdiction for tax appraisal
  projectType           String    @default("investment")     // investment, expansion, logistics_hub
  currency              String    @default("EUR")
  status                String    @default("appraisal")       // appraisal, approved, active, closed
  startYear             Int
  horizonYears          Int       @default(10)

  // Capital structure
  capexTotal            Float     @default(0)
  debtAmount            Float     @default(0)
  debtRate              Float     @default(0)                // weighted Kd
  equityAmount          Float     @default(0)

  // Appraisal parameters
  discountRate          Float     @default(0.0637)           // WACC
  terminalGrowth        Float     @default(0.035)
  taxRate               Float     @default(0.235)            // effective IRC for appraisal

  // Free-form structured assumptions + computed cash flows (JSON)
  assumptions           String?                              // JSON: capex schedule, revenue ramp, opex, residual
  cashFlows             String?                              // JSON: per-year free cash flow array

  // Computed metrics
  npv                   Float?
  irr                   Float?
  paybackYears          Float?

  description           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ==========================================
// OPERATIONAL CATALOG — products, raw materials, bill-of-materials, sales mix
//
// Bottom-up driver for the manufacturing entity's REV-* / COGS-* trial-balance
// lines. Revenue = Σ product (volume × price); COGS = Σ product volume ×
// (materials from BOM + direct labor + overhead) [+ merchandise purchase cost].
// Scoped per entity so several manufacturing entities can each carry a catalog.
// The financial layer (TrialBalance/COA) stays the single source for the
// statements; this layer simply produces the REV/COGS lines that feed it.
// ==========================================

model Product {
  id                    String    @id @default(cuid())
  entityCode            String                               // owning manufacturing/trading entity
  code                  String                               // product/family code, e.g. PRATOS
  name                  String
  productType           String    @default("manufactured")   // manufactured, merchandise
  salesPricePerUnit     Float     @default(0)                // PVU — selling price per unit
  annualVolume          Float     @default(0)                // units sold per year (annual snapshot)
  laborCostPerUnit      Float     @default(0)                // MOD — direct labor / unit (manufactured)
  overheadPerUnit       Float     @default(0)                // GGF — manufacturing overhead / unit (manufactured)
  purchaseCostPerUnit   Float     @default(0)                // PCU — purchase cost / unit (merchandise)
  sortOrder             Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  bom                   BillOfMaterial[]
  salesMix              SalesMix[]

  @@unique([entityCode, code])
  @@index([entityCode])
}

model RawMaterial {
  id                    String    @id @default(cuid())
  entityCode            String
  code                  String                               // material code, e.g. PASTA_GRES
  name                  String
  unit                  String    @default("kg")             // kg, un, l, ...
  unitCost              Float     @default(0)                // purchase price per unit
  sortOrder             Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  bomLines              BillOfMaterial[]

  @@unique([entityCode, code])
  @@index([entityCode])
}

model BillOfMaterial {
  id                    String    @id @default(cuid())
  productId             String
  product               Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  rawMaterialId         String
  rawMaterial           RawMaterial @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  quantityPerUnit       Float                                 // material units consumed per product unit

  @@unique([productId, rawMaterialId])
  @@index([rawMaterialId])
}

model SalesMix {
  id                    String    @id @default(cuid())
  productId             String
  product               Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  market                String                               // PT, UE, USA, ROW
  channel               String                               // Private_Label, Hotelaria, Retalho, E_Commerce
  weight                Float                                 // fraction of product volume; Σ per product = 1

  @@unique([productId, market, channel])
  @@index([productId])
}

// ==========================================
// SCENARIOS
// ==========================================

model Scenario {
  id                    String    @id @default(cuid())
  name                  String    @unique                    // Base Case, Optimistic, Pessimistic
  scenarioType          String                               // base, optimistic, pessimistic
  inflationRate         Float     @default(0.02)
  interestRate          Float     @default(0.03)
  fxVolatility          Float     @default(0.05)
  revenueGrowthFactor   Float     @default(1.0)
  opexGrowthFactor      Float     @default(1.0)
  capexGrowthFactor     Float     @default(1.0)
  forecastPeriods       Int       @default(12)
  description           String?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ==========================================
// APP SETTINGS (persisted user-editable config)
// Replaces the former in-memory settings store so changes survive restarts
// and behave correctly across serverless instances.
// ==========================================

model Setting {
  key                   String    @id                        // "consolidation", "currency"
  value                 String                               // JSON blob of that category's settings
  updatedAt             DateTime  @updatedAt
}

model ValidationRule {
  id                    String    @id                        // vr-001, vr-002, ... (app-assigned, stable)
  name                  String
  entityScope           String    @default("all")            // all, non-eur, ...
  severity              String    @default("error")          // error, warning
  isActive              Boolean   @default(true)
  description           String
  sortOrder             Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ==========================================
// IMPORT BATCHES (trial-balance import history)
// ==========================================

model ImportBatch {
  id                    String    @id @default(cuid())
  fileName              String    @default("csv-upload")
  recordCount           Int       @default(0)
  entityCount           Int       @default(0)
  dateRange             String    @default("")               // "YYYY-MM to YYYY-MM"
  totalAmount           Float     @default(0)
  status                String    @default("completed")      // completed, failed
  errors                String    @default("[]")             // JSON array of row-error strings
  createdAt             DateTime  @default(now())

  @@index([createdAt])
}

// ==========================================
// AI CHAT SESSIONS (financial-insights chatbot)
// ==========================================

model ChatSession {
  id                    String    @id                        // app-assigned session id
  messages              String    @default("[]")             // JSON array of { role, content }
  createdAt             DateTime  @default(now())
  lastActive            DateTime  @default(now())

  @@index([lastActive])
}
